<?xml version="1.0" encoding="UTF-8"?>
<storyflow_hll:Story
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:storyflow_hll="http://www.example.org/storyflow_hll"
    name="T3-01 Two Start Scenes"
    version="1">
  <chapters name="Blackwell" order="1">
    <scenes id="1" name="dorm" isStart="true">
      <choices id="1" label="Head to the hallway" target="//@chapters.0/@scenes.1"/>
    </scenes>
    <!-- VIOLATION: a second scene also declares isStart="true". -->
    <scenes id="2" name="hallway" isStart="true">
      <choices id="1" label="Leave the building" target="//@chapters.0/@scenes.2"/>
    </scenes>
    <scenes id="3" name="ending_outside" isEnding="true" endingType="NEUTRAL"/>
  </chapters>
</storyflow_hll:Story>
