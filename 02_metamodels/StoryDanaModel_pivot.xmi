<?xml version="1.0" encoding="ASCII"?>
<storyflow_pivot:NarrativeGraph xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:storyflow_pivot="http://www.example.org/storyflow_pivot" xsi:schemaLocation="http://www.example.org/storyflow_pivot storyflow_pivot.ecore" storyName="Dormitory Investigation" startNode="//@nodes.0">
  <variables name="juliet_helped" initialValue="false"/>
  <variables name="found_note" initialValue="false"/>
  <items id="dana_note" name="Dana's Note"/>
  <nodes id="corridor_dorm" label="corridor_dorm" description="The corridor hums under flickering fluorescents. Dana's door waits at the far end; behind another, you can hear Juliet crying. Where do you go first?" isStart="true"/>
  <nodes id="dana_room" label="dana_room" description="&quot;Dana's room is dark, the bed unmade, drawers left open. A folded note sits on the desk with your name across it. The handwriting is shaky. Do you dare read it?"/>
  <nodes id="juliet_room_confrontation" label="juliet_room_confrontation" description="Juliet's eyes are swollen, her phone face-down on the bed. The whole campus is talking and none of it is true. The note in your pocket could clear her name. She stares at you, waiting."/>
  <nodes id="hallway_exit" label="hallway_exit" description="The door clicks shut behind you. The hallway is empty now, the drama sealed away. You walk toward the stairs, the dorm settling back into silence." isAccepting="true"/>
  <edges id="corridor_dorm_choice_1" label="Go to Dana's room" source="//@nodes.0" target="//@nodes.1"/>
  <edges id="corridor_dorm_choice_2" label="Confront Juliet" source="//@nodes.0" target="//@nodes.2">
    <guard expression="found_note == true" varRefs="//@variables.1"/>
  </edges>
  <edges id="corridor_dorm_choice_3" label="Ignore" source="//@nodes.0" target="//@nodes.3"/>
  <edges id="dana_room_choice_1" label="Read the note" source="//@nodes.1" target="//@nodes.0">
    <actions targetVariable="//@variables.1"/>
    <actions type="ADD_ITEM" targetItem="//@items.0"/>
  </edges>
  <edges id="dana_room_choice_2" label="Leave note without seeing" source="//@nodes.1" target="//@nodes.0"/>
  <edges id="juliet_room_confrontation_choice_1" label="Help Juliet post a refutation" source="//@nodes.2" target="//@nodes.3">
    <actions targetVariable="//@variables.0"/>
  </edges>
  <edges id="juliet_room_confrontation_choice_2" label="Leave Juliet to handle it herself" source="//@nodes.2" target="//@nodes.3"/>
</storyflow_pivot:NarrativeGraph>
