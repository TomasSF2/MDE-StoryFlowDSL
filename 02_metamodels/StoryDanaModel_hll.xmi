<?xml version="1.0" encoding="UTF-8"?>
<storyflow_hll:Story
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:storyflow_hll="http://www.example.org/storyflow_hll"
    name="Dormitory Investigation"
    description="Max goes to Dana's dorm and investigates"
    version="1">
  <variables
      name="found_note"
      type="BOOLEAN"
      defaultValue="false"/>
  <variables
      name="juliet_helped"
      type="BOOLEAN"
      defaultValue="false"/>
  <characters
      id="max"
      name="Max"
      description="Max "/>
  <characters
      id="juliet"
      name="Juliet"
      description="Juliet Watson"/>
  <characters
      id="dana"
      name="Dana"
      description="Dana Ward"/>
  <items id="dana_note"
      name="Dana's Note"
      description="Dana's note"/>
  <chapters
      name="Dormitory Corridor"
      order="1"
      description="Dormitory corridor">
    <scenes
        id="1"
        name="corridor_dorm"
        description="The corridor hums under flickering fluorescents. Dana's door waits at the far end; behind another, you can hear Juliet crying. Where do you go first?"
        isStart="true"
        characters="//@characters.0">
      <choices
          id="1"
          label="Go to Dana's room"
          target="//@chapters.0/@scenes.1"/>
      <choices
          id="2"
          label="Confront Juliet"
          target="//@chapters.0/@scenes.2">
        <condition
            expression="found_note == true"
            referencedVars="//@variables.0"/>
      </choices>
      <choices
          id="3"
          label="Ignore"
          target="//@chapters.0/@scenes.3"/>
    </scenes>
    <scenes
        id="2"
        name="dana_room"
        description="&quot;Dana's room is dark, the bed unmade, drawers left open. A folded note sits on the desk with your name across it. The handwriting is shaky. Do you dare read it?"
        characters="//@characters.0">
      <choices
          id="1"
          label="Read the note"
          target="//@chapters.0/@scenes.0">
        <effects
            targetVar="//@variables.0"
            value="true"/>
        <effects
            type="ADD_ITEM"
            targetItem="//@items.0"
            value="true"/>
      </choices>
      <choices
          id="2"
          label="Leave note without seeing"
          target="//@chapters.0/@scenes.0"/>
    </scenes>
    <scenes
        id="3"
        name="juliet_room_confrontation"
        description="Juliet's eyes are swollen, her phone face-down on the bed. The whole campus is talking and none of it is true. The note in your pocket could clear her name. She stares at you, waiting."
        characters="//@characters.0 //@characters.1">
      <choices
          id="1"
          label="Help Juliet post a refutation"
          target="//@chapters.0/@scenes.3">
        <effects
            targetVar="//@variables.1"
            value="true"/>
      </choices>
      <choices
          id="2"
          label="Leave Juliet to handle it herself"
          target="//@chapters.0/@scenes.3"/>
    </scenes>
    <scenes
        id="4"
        name="hallway_exit"
        description="The door clicks shut behind you. The hallway is empty now, the drama sealed away. You walk toward the stairs, the dorm settling back into silence."
        isEnding="true"
        endingType="NEUTRAL"
        characters="//@characters.0"/>
  </chapters>
</storyflow_hll:Story>
