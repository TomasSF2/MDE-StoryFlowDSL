rule Graph2NuSMV
    transform g : Pivot!NarrativeGraph {
    template : "generate_nusmv.egl"
    target : g.pivotFileBaseName() + ".smv"
}

operation Any pivotFileBaseName() : String {
    // Uses the EMF resource URI of the loaded pivot .xmi.
    // Example: StoryDarkRoomModel_pivot.xmi -> StoryDarkRoomModel_pivot.smv
    return self.eResource().getURI().trimFileExtension().lastSegment();
}